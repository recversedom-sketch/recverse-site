---
import BaseLayout from "../layouts/BaseLayout.astro";

const sp = Astro.url.searchParams;
const preTopic = sp.get("topic") ?? "";
const preModule = sp.get("module") ?? "";
const prePackage = sp.get("package") ?? "";

const topicOptions = [
  "Erstgespräch",
  "Brainstorming",
  "KI-Einstieg / Orientierung",
  "KI-MVP / PoC",
  "ERP / IT-Projektmanagement",
  "Web-Präsenz / Redesign",
  "Website Datenschutz-Check",
  "Website Renewal / SEO",
  "Laufende Begleitung",
  "Etwas anderes",
];

const normalizedPreTopic = topicOptions.includes(preTopic) ? preTopic : "";

const prefill =
  prePackage ? `Paket: ${prePackage}\n` :
  preModule ? `Modul: ${preModule}\n` :
  normalizedPreTopic ? `Thema: ${normalizedPreTopic}\n` : "";
---

<BaseLayout
  title="Erstgespräch / Anfrage — Recverse"
  description="Beschreiben Sie kurz Ihre Situation. Sie erhalten eine konkrete Rückmeldung zu sinnvollen nächsten Schritten."
>
  <section class="section">
    <div class="container" style="max-width: 820px;">
      <div class="kicker">Kontakt</div>
      <h1 class="h1">Starten Sie mit einem klaren ersten Gespräch</h1>
      <p class="p">
        Wenn Sie das Gefühl haben, technologisch unter Druck zu stehen oder nicht genau wissen, wo Sie sinnvoll ansetzen sollen,
        beschreiben Sie uns kurz Ihre Situation. Sie erhalten eine konkrete Rückmeldung zu möglichen nächsten Schritten.
      </p>

      <div class="card" style="padding:16px; margin-top:18px;">
        <div class="muted" style="line-height:1.7;">
          <strong style="color:inherit;">Typische Anliegen:</strong><br />
          KI sinnvoll einordnen · Prozesse effizienter machen · Tool-Chaos reduzieren · Orientierung gewinnen · technologische Prioritäten klären
        </div>
      </div>

      <form
        name="angebot"
        method="POST"
        action="/thanks/"
        data-netlify="true"
        data-netlify-honeypot="bot-field"
        class="card"
        style="margin-top:18px; padding:18px;"
      >
        <input type="hidden" name="form-name" value="angebot" />

        <!-- Honeypot -->
        <p style="position:absolute; left:-9999px; height:0; overflow:hidden;">
          <label>Don’t fill this out: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
        </p>

        <!-- Time-trap + JS-gate -->
        <input type="hidden" name="tt_start" value="0" />
        <input type="hidden" name="js_ok" value="0" />

        <div class="grid grid-2">
          <label style="display:grid; gap:8px;">
            <span class="muted">Name (Pflicht)</span>
            <input
              name="name"
              required
              autocomplete="name"
              class="card"
              style="padding:12px; background:rgba(0,0,0,.15);"
            />
          </label>

          <label style="display:grid; gap:8px;">
            <span class="muted">E-Mail (Pflicht)</span>
            <input
              name="email"
              type="email"
              required
              autocomplete="email"
              class="card"
              style="padding:12px; background:rgba(0,0,0,.15);"
            />
          </label>
        </div>

        <div class="grid grid-2" style="margin-top:12px;">
          <label style="display:grid; gap:8px;">
            <span class="muted">Firma (optional)</span>
            <input
              name="company"
              autocomplete="organization"
              class="card"
              style="padding:12px; background:rgba(0,0,0,.15);"
            />
          </label>

          <label style="display:grid; gap:8px;">
            <span class="muted">Telefon (optional)</span>
            <input
              name="phone"
              type="tel"
              autocomplete="tel"
              class="card"
              style="padding:12px; background:rgba(0,0,0,.15);"
            />
          </label>
        </div>

        <div class="grid grid-2" style="margin-top:12px;">
          <label style="display:grid; gap:8px;">
            <span class="muted">Worum geht es?</span>
            <select name="topic" class="card" style="padding:12px; background:rgba(0,0,0,.15);">
              {topicOptions.map((opt) => (
                <option value={opt} selected={normalizedPreTopic === opt}>{opt}</option>
              ))}
            </select>
          </label>

          <label style="display:grid; gap:8px;">
            <span class="muted">Zeitrahmen (optional)</span>
            <select name="timeline" class="card" style="padding:12px; background:rgba(0,0,0,.15);">
              <option value="">—</option>
              <option>sofort / diese Woche</option>
              <option>2–4 Wochen</option>
              <option>1–3 Monate</option>
              <option>später / noch offen</option>
            </select>
          </label>
        </div>

        <div class="grid grid-2" style="margin-top:12px;">
          <label style="display:grid; gap:8px;">
            <span class="muted">Budgetrahmen (optional)</span>
            <select name="budget" class="card" style="padding:12px; background:rgba(0,0,0,.15);">
              <option value="">—</option>
              <option>unter CHF 500</option>
              <option>CHF 500–1'500</option>
              <option>CHF 1'500–5'000</option>
              <option>CHF 5'000+</option>
              <option>noch offen</option>
            </select>
          </label>

          <label style="display:grid; gap:8px;">
            <span class="muted">Rolle / Funktion (optional)</span>
            <input
              name="role"
              placeholder="z. B. Geschäftsführung, Teamleitung"
              class="card"
              style="padding:12px; background:rgba(0,0,0,.15);"
            />
          </label>
        </div>

        <label style="display:grid; gap:8px; margin-top:12px;">
          <span class="muted">Kurzbeschreibung (Pflicht)</span>
          <textarea
            name="message"
            required
            rows="8"
            class="card"
            style="padding:12px; background:rgba(0,0,0,.15);"
            placeholder="Beschreiben Sie kurz Ihre aktuelle Situation, wo Sie Überforderung, Unsicherheit oder Effizienzpotenzial sehen und was Sie sich vom Gespräch erhoffen."
          >{prefill}</textarea>
        </label>

        <p class="muted" style="font-size:12px; margin-top:10px; line-height:1.6;">
          Bitte senden Sie im Erstkontakt keine sensiblen Informationen. Mit dem Absenden erklären Sie sich mit der
          Verarbeitung Ihrer Angaben zur Bearbeitung Ihrer Anfrage einverstanden. Details siehe
          <a class="muted" style="text-decoration:underline;" href="/privacy/"> Datenschutz</a>.
        </p>

        <div style="display:flex; gap:12px; align-items:center; flex-wrap:wrap; margin-top:14px;">
          <button type="submit" class="btn btn-primary">Anfrage senden</button>
          <a class="btn btn-secondary" href="/services/">Leistungen ansehen</a>
        </div>
      </form>

      <noscript>
        <div class="card" style="padding:14px; margin-top:14px;">
          <strong>Hinweis:</strong>
          <div class="muted" style="margin-top:6px;">
            JavaScript ist deaktiviert. Das Formular funktioniert möglicherweise, der Spam-Schutz ist dann aber eingeschränkt.
          </div>
        </div>
      </noscript>
    </div>
  </section>

  <script is:inline>
    const form = document.querySelector('form[name="angebot"]');
    if (form) {
      const start = Date.now();
      const tt = form.querySelector('input[name="tt_start"]');
      const jsok = form.querySelector('input[name="js_ok"]');
      if (tt) tt.value = String(start);
      if (jsok) jsok.value = "1";

      form.addEventListener("submit", (e) => {
        const elapsed = Date.now() - start;
        if (elapsed < 3000) {
          e.preventDefault();
          alert("Bitte kurz prüfen und danach senden (Spam-Schutz).");
          return;
        }
        if (jsok && jsok.value !== "1") {
          e.preventDefault();
          alert("Bitte erneut versuchen.");
          return;
        }
      });
    }
  </script>
</BaseLayout>