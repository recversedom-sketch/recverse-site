---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Legal Notice — Recverse" description="Legal notice and provider information.">
  <main class="landing-page landing-page--impressum">
    <section class="section legal-section">
      <div class="container legal-container">
        <p class="eyebrow">Legal</p>
        <h1>Legal Notice</h1>
        <p class="lead legal-lead">
          Provider information and legal notes in a simple format.
        </p>

        <div class="legal-box">
          <h2>Provider</h2>
          <p><strong>Domenico Recchia</strong></p>
          <p>6042 Dietwil, Aargau, Switzerland</p>
          <p>
            <strong>Contact:</strong> Please use the
            <a href="/en/contact/">contact form</a>.
          </p>
        </div>

        <div class="legal-box legal-box--subtle">
          <h2>Liability notice</h2>
          <p>
            All content is created with due care. No guarantee is given for accuracy, completeness,
            or timeliness. Links to external websites are outside the area of responsibility of
            Domenico Recchia.
          </p>
        </div>
      </div>
    </section>
  </main>

  <style>
    .landing-page--impressum .legal-section {
      padding-top: 6.5rem;
      padding-bottom: 5rem;
    }

    .landing-page--impressum .legal-container {
      max-width: 760px;
    }

    .landing-page--impressum h1 {
      max-width: none;
      margin-bottom: 0.75rem;
    }

    .landing-page--impressum .legal-lead {
      max-width: 52ch;
      margin-bottom: 2rem;
    }

    .landing-page--impressum .legal-box {
      background: var(--rv-bg-soft);
      border: 1px solid var(--rv-border);
      border-radius: 18px;
      padding: 1.25rem 1.35rem;
      margin-top: 1rem;
    }

    .landing-page--impressum .legal-box h2 {
      font-size: 1.2rem;
      max-width: none;
      margin-bottom: 0.9rem;
    }

    .landing-page--impressum .legal-box p {
      margin: 0 0 0.7rem;
      color: var(--rv-text-soft);
      line-height: 1.7;
    }

    .landing-page--impressum .legal-box p:last-child {
      margin-bottom: 0;
    }

    .landing-page--impressum .legal-box a {
      color: var(--rv-accent);
      text-decoration: underline;
    }

    .landing-page--impressum .legal-box--subtle {
      background: rgba(255, 255, 255, 0.025);
      box-shadow: none;
    }

    @media (max-width: 640px) {
      .landing-page--impressum .legal-section {
        padding-top: 5.5rem;
      }

      .landing-page--impressum .legal-box {
        padding: 1rem 1.05rem;
      }
    }
  </style>
</BaseLayout>